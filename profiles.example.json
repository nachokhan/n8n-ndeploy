{
  "schema_version": 1,
  "profiles": {
    "dev-to-prod": {
      "source": {
        "url": "https://dev.example.com",
        "api_key": "dev_api_key",
        "credential_export_url": "https://dev.example.com/webhook/credential-export",
        "credential_export_token": "dev_export_token"
      },
      "target": {
        "url": "https://prod.example.com",
        "api_key": "prod_api_key",
        "credential_export_url": "https://prod.example.com/webhook/credential-export",
        "credential_export_token": "prod_export_token"
      }
    },
    "dev-to-smith-local": {
      "source": {
        "url": "https://dev.example.com",
        "api_key": "dev_api_key"
      },
      "target": {
        "url": "http://localhost:5678",
        "api_key": "smith_local_api_key"
      }
    }
  }
}
